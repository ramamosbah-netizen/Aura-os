PORT=4000

# Supabase (Postgres + Auth + RLS) — wired in the next increment
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=

# Intelligence layer — AI providers (Claude is the default)
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GEMINI_API_KEY=

# Embeddings (pgvector RAG). Unset -> deterministic offline LEXICAL embedding.
# Set EMBEDDINGS_API_KEY for real neural embeddings via an OpenAI-compatible API.
# The model must emit EMBEDDINGS_DIMS-dimensional vectors matching the vector() column.
# EMBEDDINGS_API_KEY=
# EMBEDDINGS_BASE_URL=https://api.openai.com/v1   # or https://api.voyageai.com/v1
# EMBEDDINGS_MODEL=text-embedding-3-small         # 1536 dims
# EMBEDDINGS_DIMS=1536
