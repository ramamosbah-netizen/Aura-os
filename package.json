{
  "name": "aura-os",
  "version": "0.0.0",
  "private": true,
  "description": "AURA OS — Tier-1 ERP Operating System (modular monolith). See docs/AURA-OS-V2-BLUEPRINT.md.",
  "packageManager": "pnpm@11.8.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "db:migrate": "pnpm --filter @aura/api db:migrate",
    "test:coverage": "turbo run test -- --coverage",
    "audit": "pnpm audit --prod"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@vitest/coverage-v8": "^3.2.6",
    "eslint": "^9.39.4",
    "globals": "^17.7.0",
    "turbo": "^2.3.3",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.62.1"
  }
}
